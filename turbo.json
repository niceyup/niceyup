{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "start": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "dev": {
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {}
  },
  "globalEnv": [
    "APP_ENV",
    "APP_SECRET_KEY",
    "API_URL",
    "WEB_URL",
    "STORAGE_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WEB_URL",
    "NEXT_PUBLIC_WEBSOCKET_URL",
    "NEXT_PUBLIC_STORAGE_URL",
    "NEXT_CONFIG_OUTPUT",
    "ENCRYPTION_KEY",
    "UPLOAD_SECRET",
    "BETTER_AUTH_SECRET",
    "DATABASE_URL",
    "REDIS_URL",
    "S3_DEFAULT_BUCKET",
    "S3_ENGINE_BUCKET",
    "S3_REGION",
    "S3_ENDPOINT",
    "S3_ACCOUNT_ID",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "TRIGGER_API_URL",
    "TRIGGER_PROJECT_REF",
    "TRIGGER_SECRET_KEY",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "NOVU_SECRET_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_HOBBY_PLAN_PRICE_ID",
    "STRIPE_HOBBY_PLAN_AI_USAGE_PRICE_ID",
    "STRIPE_HOBBY_PLAN_COMPUTE_USAGE_PRICE_ID",
    "STRIPE_STANDARD_PLAN_PRICE_ID",
    "STRIPE_STANDARD_PLAN_AI_USAGE_PRICE_ID",
    "STRIPE_STANDARD_PLAN_COMPUTE_USAGE_PRICE_ID",
    "STRIPE_ADVANCED_PLAN_PRICE_ID",
    "STRIPE_ADVANCED_PLAN_AI_USAGE_PRICE_ID",
    "STRIPE_ADVANCED_PLAN_COMPUTE_USAGE_PRICE_ID",
    "STRIPE_AI_USAGE_METER_ID",
    "STRIPE_COMPUTE_USAGE_METER_ID",
    "CURRENCY_API_KEY"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "PORT",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event"
  ]
}
